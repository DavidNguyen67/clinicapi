# Database Configuration (H2 Local Database)
# Dữ liệu sẽ được lưu trong file ./data/clinicdb
SPRING_DATASOURCE_URL=example:jdbc:h2:file:./data/clinicdb;DB_CLOSE_ON_EXIT=FALSE;AUTO_SERVER=TRUE
SPRING_DATASOURCE_USERNAME=example
SPRING_DATASOURCE_PASSWORD=example

# JWT Configuration (RSA Keys)
JWT_PRIVATE_KEY_PATH=example
JWT_PUBLIC_KEY_PATH=example
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
JWT_REFRESH_COOKIE_NAME=refreshToken

# Server Configuration
SERVER_PORT=8080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# API Key Security Configuration
API_KEY_ENABLED=true

# Comma-separated list of valid API keys
API_KEYS=example
