# Database Configuration
SPRING_DATASOURCE_URL=example:jdbc:mysql://localhost:3306/clinic_db
SPRING_DATASOURCE_USERNAME=example_user
SPRING_DATASOURCE_PASSWORD=example_password

# JWT Configuration (RSA Keys)
# Run: scripts/generate-keys.ps1 (Windows) or scripts/generate-keys.sh (Linux/Mac)
JWT_PRIVATE_KEY_PATH=keys/private_key_pkcs8.pem
JWT_PUBLIC_KEY_PATH=keys/public_key.pem
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Server Configuration
SERVER_PORT=8080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# API Key Security Configuration
API_KEY_ENABLED=true

# Comma-separated list of valid API keys
API_KEYS=example-api-key-1,example-api-key-2,example-api-key-3
