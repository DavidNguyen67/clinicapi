# Database Configuration
SPRING_DATASOURCE_URL=example   
SPRING_DATASOURCE_USERNAME=example
SPRING_DATASOURCE_PASSWORD=example
MONGODB_URI=example
MONGODB_DATABASE=example

# JWT Configuration (RSA Keys)
JWT_PRIVATE_KEY_PATH="keys/private_key_pkcs8.pem"
JWT_PUBLIC_KEY_PATH="keys/public_key.pem"
JWT_EXPIRATION=86400000 # 24 hours in milliseconds
JWT_REFRESH_EXPIRATION=604800000 # 7 days in milliseconds
JWT_REFRESH_COOKIE_NAME=refreshToken

# Email Configuration (Gmail SMTP)
MAIL_HOST=example
MAIL_PORT=587
MAIL_USERNAME=example
MAIL_PASSWORD=example

# Server Configuration
SERVER_PORT=8080
SPRINGDOC_SWAGGER-UI_ENABLED=true
SPRINGDOC_API_DOCS_ENABLED=true

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# API Key Security Configuration
API_KEY_ENABLED=true

# Comma-separated list of valid API keys
API_KEYS=example

# Frontend URL Configuration
FRONTEND_URL=http://localhost:3000