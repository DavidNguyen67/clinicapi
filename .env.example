# Database Configuration
SPRING_DATASOURCE_URL="jdbc:postgresql://your-host.supabase.co:5432/postgres"
SPRING_DATASOURCE_USERNAME="your-username"
SPRING_DATASOURCE_PASSWORD="your-password"
MONGODB_URI="mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?retryWrites=true&w=majority&appName=your-cluster"
MONGODB_DATABASE="clinic_db"

# JWT Configuration (RSA Keys)
JWT_PRIVATE_KEY_PATH="keys/private_key_pkcs8.pem"
JWT_PUBLIC_KEY_PATH="keys/public_key.pem"
JWT_EXPIRATION=86400000 # 24 hours in milliseconds
JWT_REFRESH_EXPIRATION=604800000 # 7 days in milliseconds
JWT_REFRESH_COOKIE_NAME=refreshToken

# Email Configuration (Gmail SMTP)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USERNAME="your-email@gmail.com"
MAIL_PASSWORD="your-app-password-here"

# Server Configuration
SERVER_PORT=8080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# API Key Security Configuration
API_KEY_ENABLED=true

# Comma-separated list of valid API keys
API_KEYS=your-api-key-here
